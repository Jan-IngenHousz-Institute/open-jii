# Python / uv
.venv/
.python-version-local
# The repo-root .gitignore excludes .python-version globally; un-ignore here
# so this app's pinned uv Python version is tracked.
!.python-version
dist/
build/
*.egg
*.egg-info/
*.whl

# Bytecode + caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.mypy_cache/
.pyright/

# Databricks
.databricks/

# IDE
.vscode/
.idea/
.DS_Store
