{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "24.18.0",
      "pnpm": "11.15.0"
    },
    "preview": {
      "extends": "base",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "internal": {
      "extends": "base",
      "channel": "internal",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    },
    "beta": {
      "extends": "base",
      "channel": "beta",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production": {
      "extends": "base",
      "channel": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "internal": {
      "android": {
        "track": "internal"
      }
    },
    "beta": {
      "android": {
        "track": "beta"
      }
    },
    "production": {
      "android": {
        "track": "production"
      }
    }
  }
}
