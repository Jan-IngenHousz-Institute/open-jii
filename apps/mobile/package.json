  "name": "mobile",
  "version": "1.1.0",
  "main": "index.tsx",
  "scripts": {
    "clean": "git clean -xdf .cache .expo .turbo android ios node_modules",
    "dev": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "build-apk": "dotenv -- eas build -p android --profile preview --local",
    "build-aab-locally": "dotenv -- eas build -p android --profile internal --local",
    "submit-to-google-play": "eas build -p android --profile internal --clear-cache --non-interactive --auto-submit",
    "update:preview": "eas update --branch preview",
    "update:internal": "eas update --branch internal",
    "update:beta": "eas update --branch beta",
    "update:production": "eas update --branch production",
    "adb:reverse": "adb reverse tcp:3020 tcp:3020 && adb reverse tcp:3000 tcp:3000 && adb reverse tcp:8081 tcp:8081",
    "build": "expo export --platform android",
    "build:debug": "pnpm prebuild:check && cd android && ./gradlew assembleDebug -x lint -x test",
    "build:release": "pnpm prebuild:check && cd android && ./gradlew assembleRelease -x lint -x test",
    "build:preview": "dotenv -- pnpm dlx eas-cli build -p android --profile preview --local",
    "build:production": "dotenv -- pnpm dlx eas-cli build -p android --profile production --local",
    "build:submit": "pnpm dlx eas-cli build -p android --profile production --clear-cache --non-interactive --auto-submit",
    "prebuild:check": "expo prebuild --platform android --no-install",
    "lint": "eslint 'src/**/*' --fix",
    "typecheck": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "assert-new-arch": "tsx scripts/assert-new-arch.ts",
    "postinstall": "cd ../../packages/api && pnpm run build && cd - && cd ../../packages/transactional && pnpm run build && cd - && cd ../../packages/auth && pnpm run build && cd - && cd ../../packages/iot && pnpm run build && cd - && cd ../../packages/cms && pnpm run build && cd -"
  },
