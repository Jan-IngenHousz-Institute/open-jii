  "scripts": {
    "clean": "git clean -xdf .cache .expo .turbo android ios node_modules",
    "start": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "build-apk": "echo 'node-linker=hoisted' > .npmrc && dotenv -- eas build -p android --profile preview --local && rm .npmrc",
    "build-aab-locally": "dotenv -- eas build -p android --profile production --local",
    "submit-to-google-play": "eas build -p android --profile production --clear-cache --non-interactive --auto-submit",
    "lint": "eslint 'src/**/*' --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "postinstall": "cd ../../packages/api && pnpm run build && cd - && cd ../../packages/transactional && pnpm run build && cd - && cd ../../packages/auth && pnpm run build && cd -"
  },
