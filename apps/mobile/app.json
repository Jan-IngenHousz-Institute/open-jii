{
  "expo": {
    "scheme": ["openjii"],
    "name": "openJII",
    "slug": "openjii",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.openjii.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "openJII uses your location to determine your timezone for accurate measurement timestamps."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#D3D3D3"
      },
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": ["android.permission.RECORD_AUDIO"],
      "package": "com.openjii.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "react-native-ble-plx",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E2FCFC",
          "image": "./assets/splash-icon-rounded.png",
          "resizeMode": "cover",
          "imageWidth": 140
        }
      ],
      [
        "react-native-permissions",
        {
          "iosPermissions": ["Bluetooth"]
        }
      ],
      [
        "./plugins/with-bluetooth-classic",
        {
          "peripheralUsageDescription": "Allow myDevice to check bluetooth peripheral info",
          "alwaysUsageDescription": "Allow myDevice to always use bluetooth info",
          "protocols": ["com.myCompany.p1", "com.myCompany.p2"]
        }
      ],
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-asset",
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "openJII uses your location to determine your timezone for accurate measurement timestamps."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "openJII uses the camera to scan QR codes during measurements.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ]
    ],
    "experiments": {
      "autolinkingModuleResolution": true
    },
    "extra": {
      "expo-router": {
        "appRoot": "./app"
      },
      "eas": {
        "projectId": "d2dd70d8-9b41-41f2-b587-41ba0b18690f"
      }
    }
  }
}
