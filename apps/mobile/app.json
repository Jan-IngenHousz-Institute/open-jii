{
  "expo": {
    "scheme": ["openjii"],
    "name": "openJII",
    "slug": "openjii",
    "version": "1.1.0",
    "orientation": "default",
    "icon": "./assets/adaptive-icon.png",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/d2dd70d8-9b41-41f2-b587-41ba0b18690f",
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.openjii.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "openJII uses your location to determine your timezone and to record where each measurement was taken."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#D3D3D3"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": ["android.permission.RECORD_AUDIO"],
      "package": "com.openjii.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "react-native-ble-plx",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E2FCFC",
          "image": "./assets/splash-icon-rounded.png",
          "resizeMode": "cover",
          "imageWidth": 140
        }
      ],
      [
        "react-native-permissions",
        {
          "iosPermissions": ["Bluetooth"]
        }
      ],
      [
        "./plugins/with-bluetooth-classic",
        {
          "peripheralUsageDescription": "openJII uses Bluetooth to connect to MultispeQ measurement devices.",
          "alwaysUsageDescription": "openJII uses Bluetooth to connect to MultispeQ measurement devices."
        }
      ],
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-asset",
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "openJII uses your location to determine your timezone and to record where each measurement was taken."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "openJII uses the camera to scan QR codes during measurements.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      "expo-audio",
      "expo-secure-store",
      "expo-sharing",
      "expo-sqlite"
    ],
    "experiments": {
      "autolinkingModuleResolution": true
    },
    "extra": {
      "expo-router": {
        "appRoot": "./app"
      },
      "eas": {
        "projectId": "d2dd70d8-9b41-41f2-b587-41ba0b18690f"
      }
    }
  }
}
