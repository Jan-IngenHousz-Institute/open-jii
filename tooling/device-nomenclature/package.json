{
  "name": "@repo/device-nomenclature",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "check": "pnpm build && node dist/cli.js",
    "check:frozen-history": "node dist/frozen-history-cli.js",
    "check-types": "tsc --noEmit",
    "clean": "git clean -xdf .cache .turbo dist node_modules reports",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path ../../.prettierignore",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/api": "workspace:*",
    "@repo/database": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/iot": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:testing"
  }
}
