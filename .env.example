# Database configuration
# These variables are validated by @repo/env
POSTGRES_DB=openjii_local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openjii_local

# Node environment (development, test, or production)
NODE_ENV=development

# Add additional environment variables as needed
# Client-side public variables must be prefixed with PUBLIC_