{
  "title": "� User Registrations",
  "uid": "${environment}-user-registrations",
  "tags": ["database", "postgresql", "users", "${environment}"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1h",
  "time": {
    "from": "now-1y",
    "to": "now"
  },
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "${postgres_datasource_uid}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "10.4.1",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${postgres_datasource_uid}" },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS \"Total Users\" FROM users",
          "refId": "A"
        }
      ],
      "title": "Total Registered Users",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${postgres_datasource_uid}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "10.4.1",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${postgres_datasource_uid}" },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS \"This Week\" FROM users WHERE created_at >= DATE_TRUNC('week', NOW())",
          "refId": "A"
        }
      ],
      "title": "Registered This Week",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${postgres_datasource_uid}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "10.4.1",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${postgres_datasource_uid}" },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS \"Last 30 Days\" FROM users WHERE created_at >= NOW() - INTERVAL '30 days'",
          "refId": "A"
        }
      ],
      "title": "Registered (Last 30 Days)",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "${postgres_datasource_uid}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Users",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short",
          "displayName": "New Users"
        },
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 4 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${postgres_datasource_uid}" },
          "format": "time_series",
          "rawSql": "SELECT\n  DATE_TRUNC('week', created_at) AS time,\n  COUNT(*) AS \"New Users\"\nFROM users\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "New User Registrations per Week",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "${postgres_datasource_uid}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "user_count" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "color-background" } },
              { "id": "custom.width", "value": 200 },
              { "id": "displayName", "value": "Registrations" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "year" },
            "properties": [{ "id": "custom.width", "value": 100 }]
          },
          {
            "matcher": { "id": "byName", "options": "week_number" },
            "properties": [
              { "id": "custom.width", "value": 120 },
              { "id": "displayName", "value": "ISO Week" }
            ]
          }
        ]
      },
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 16 },
      "id": 11,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": ["user_count"],
          "reducer": ["sum"],
          "show": true
        },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "year" }]
      },
      "pluginVersion": "10.4.1",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${postgres_datasource_uid}" },
          "format": "table",
          "rawSql": "SELECT\n  EXTRACT(ISOYEAR FROM created_at) AS year,\n  EXTRACT(WEEK FROM created_at) AS week_number,\n  COUNT(*) AS user_count\nFROM users\nGROUP BY year, week_number\nORDER BY year, week_number",
          "refId": "A"
        }
      ],
      "title": "User Registrations by ISO Year & Week",
      "type": "table"
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "style": "dark"
}
