{
  "name": "@repo/transactional",
  "version": "1.0.0",
  "private": true,
  "exports": {
    "./emails/email": {
      "types": "./dist/emails/email.d.ts",
      "default": "./dist/emails/email.js"
    },
    "./emails/verification-request": {
      "types": "./dist/emails/verification-request.d.ts",
      "default": "./dist/emails/verification-request.js"
    },
    "./render/otp-email": {
      "types": "./dist/render/otp-email.d.ts",
      "default": "./dist/render/otp-email.js"
    },
    "./render/verification-request": {
      "types": "./dist/render/verification-request.d.ts",
      "default": "./dist/render/verification-request.js"
    },
    "./render/added-user-notification": {
      "types": "./dist/render/added-user-notification.d.ts",
      "default": "./dist/render/added-user-notification.js"
    },
    "./render/transfer-request-confirmation": {
      "types": "./dist/render/transfer-request-confirmation.d.ts",
      "default": "./dist/render/transfer-request-confirmation.js"
    },
    "./render/project-transfer-complete": {
      "types": "./dist/render/project-transfer-complete.d.ts",
      "default": "./dist/render/project-transfer-complete.js"
    }
  },
  "scripts": {
    "build": "tsc --build --verbose",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "test:render": "pnpm build && node --env-file=../../apps/backend/.env scripts/test-render.mjs",
    "dev": "tsc --watch & email dev -p 3001 & sleep 1 && pnpm start:mailcatcher",
    "email:dev": "email dev -p 3001 & sleep 1 && pnpm start:mailcatcher",
    "export": "email export",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "start:mailcatcher": "docker compose -f docker-compose.yml up mailcatcher"
  },
  "dependencies": {
    "@react-email/components": "^0.3.3",
    "@repo/cms": "workspace:*",
    "emailmd": "^0.1.4",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.17.2"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.2.8",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/qrcode": "^1.5.6",
    "@types/react": "catalog:react19",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "catalog:",
    "react": "catalog:react19",
    "react-email": "5.2.8",
    "typescript": "catalog:"
  }
}
