{
  "name": "@repo/i18n",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./config": {
      "import": "./src/config.ts",
      "types": "./src/config.ts"
    },
    "./server": {
      "import": "./src/server.ts",
      "types": "./src/server.ts"
    },
    "./client": {
      "import": "./src/client.ts",
      "types": "./src/client.ts"
    },
    "./locales/*": "./locales/*"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.5",
    "i18next-resources-to-backend": "^1.2.1",
    "next-i18n-router": "^5.5.6",
    "react-i18next": "^15.7.4"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@types/react": "catalog:react19",
    "eslint": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "next": "catalog:",
    "react": "catalog:"
  }
}
