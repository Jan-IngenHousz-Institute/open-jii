{
  "name": "open-jii",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "clean": "git clean -xdf node_modules .turbo",
    "clean:workspaces": "turbo run clean && pnpm run clean",
    "dev": "turbo dev --concurrency 13",
    "build:affected": "turbo build --affected",
    "check:affected": "turbo ls --affected",
    "format": "prettier --write \"**/*.{ts,tsx,js,md,mdx,css,yaml,yml,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,md,mdx,css,yaml,yml,json}\"",
    "lint": "turbo run lint --continue -- --no-cache",
    "lint:fix": "turbo run lint --continue -- --fix --no-cache",
    "lint:ws": "pnpm dlx sherif@latest",
    "test": "turbo test",
    "test:watch": "turbo test --watch",
    "test:coverage": "turbo test --coverage",
    "test:projects": "vitest run",
    "test:projects:watch": "vitest --watch",
    "view-report": "turbo run view-report",
    "tf": "pnpm run tf:dev",
    "tf:fmt": "cd infrastructure && tofu fmt --recursive",
    "tf:dev": "cd infrastructure/env/dev && tofu init && tofu plan && tofu apply",
    "db:migrate": "turbo db:migrate",
    "db:generate": "turbo --filter database db:generate",
    "db:studio": "turbo --filter database db:studio",
    "db:setup": "turbo db:setup",
    "postinstall": "pnpm lint:ws",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "dev:fb": "turbo run dev --filter=backend --filter=web"
  },
  "devDependencies": {
    "@repo/vitest-config": "workspace:*",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "0.6.12",
    "turbo": "^2.3.3",
    "typescript": "catalog:",
    "vitest": "catalog:testing"
  },
  "packageManager": "pnpm@10.7.1+sha512.2d92c86b7928dc8284f53494fb4201f983da65f0fb4f0d40baafa5cf628fa31dae3e5968f12466f17df7e97310e30f343a648baea1b9b350685dafafffdf5808",
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "react": "catalog:react19",
    "react-dom": "catalog:react19"
  },
  "patchedDependencies": {
    "react-native-usb-serialport-for-android": "patches/react-native-usb-serialport-for-android.patch",
    "@better-auth/expo": "patches/@better-auth__expo.patch",
    "react-native-usb-serialport-for-android@0.5.0": "patches/react-native-usb-serialport-for-android.patch"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tooling/*"
    ],
    "catalog": {
      "axios": "^1.13.5",
      "typescript": "^5.8.3",
      "zod": "^3.24.3",
      "eslint": "^9.25.1",
      "prettier": "^3.5.3",
      "react-hook-form": "^7.56.2",
      "tailwindcss": "^3.4.15",
      "@types/node": "^22.15.3",
      "nodemailer": "^7.0.11",
      "@types/nodemailer": "^7.0.9",
      "posthog-js": "^1.279.1",
      "posthog-node": "^5.10.2",
      "next": "^15.5.10"
    },
    "catalogs": {
      "react19": {
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "@types/react": "^19.0.12",
        "@types/react-dom": "^19.0.4"
      },
      "react-query": {
        "@tanstack/react-query": "^5.84.1",
        "@tanstack/react-query-devtools": "^5.84.1",
        "@tanstack/query-async-storage-persister": "^5.83.1",
        "@tanstack/react-query-persist-client": "^5.84.1"
      },
      "testing": {
        "vitest": "^3.2.4",
        "jsdom": "^26.0.0",
        "@vitest/coverage-v8": "^3.2.4",
        "@vitest/ui": "^3.2.4",
        "@testing-library/react": "^16.3.0",
        "@testing-library/jest-dom": "^6.6.8",
        "@testing-library/user-event": "^14.6.1",
        "@vitejs/plugin-react": "^4.3.4"
      },
      "aws-sdk": {
        "@aws-sdk/client-cognito-identity": "^3.995.0",
        "@aws-sdk/client-location": "^3.995.0"
      }
    }
  }
}
